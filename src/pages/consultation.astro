---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Inisiasi Proyek & Konsultasi | Hiperkreatif"
  description="Kami siap membantu mentransformasi dan mengoptimasi operasional digital bisnis Anda. Isi brief di sini untuk menjadwalkan panggilan discovery."
>
  <!-- Architectural Layout Grid -->
  <div class="max-w-6xl mx-auto border-x border-white/10 relative min-h-screen flex flex-col">
    
    <!-- Top Nodes -->
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -left-[3px] z-30"></div>
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -right-[3px] z-30"></div>

    <section class="relative pt-24 pb-12 overflow-hidden border-b border-white/10">
      <div class="absolute inset-0 z-0 bg-grid-pattern pointer-events-none opacity-50"></div>
      
      <div class="container mx-auto px-6 lg:px-12 relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 text-white mb-8 border border-white/20 uppercase tracking-widest text-xs font-bold backdrop-blur-sm">
          <span class="w-1.5 h-1.5 bg-white animate-pulse"></span>
          Discovery Call
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 text-white max-w-4xl uppercase">
          Inisiasi Proyek
        </h1>

        <p class="text-xl md:text-2xl font-medium text-gray-400 max-w-3xl leading-snug">
          Kami tidak menerima semua proyek. Kami hanya bekerja sama dengan bisnis yang serius ingin memangkas inefisiensi operasional dan mendominasi industrinya.
        </p>
      </div>
    </section>

    <section class="flex flex-col lg:flex-row flex-grow divide-y lg:divide-y-0 lg:divide-x divide-white/10 relative bg-white/[0.01]">
      
      <!-- Left Column: Expectations -->
      <div class="lg:w-5/12 p-6 lg:p-12 relative">
        <h2 class="text-2xl font-black text-white uppercase tracking-tighter mb-8">Ekspektasi Kerja Sama</h2>
        
        <ul class="space-y-8">
          <li class="relative pl-6 border-l border-white/20">
            <div class="absolute w-1.5 h-1.5 bg-white -left-[3px] top-2"></div>
            <h3 class="font-bold text-white text-lg mb-2 uppercase tracking-wide">Fokus pada ROI</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Kami merancang sistem untuk mengembalikan investasi Anda (ROI) berkali-kali lipat, bukan sekadar mempercantik tampilan.</p>
          </li>
          <li class="relative pl-6 border-l border-white/20">
            <div class="absolute w-1.5 h-1.5 bg-white -left-[3px] top-2"></div>
            <h3 class="font-bold text-white text-lg mb-2 uppercase tracking-wide">Transparansi Absolut</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Anda akan mendapatkan laporan berkala, akses langsung ke tim teknis, dan timeline yang tidak pernah molor.</p>
          </li>
          <li class="relative pl-6 border-l border-white/20">
            <div class="absolute w-1.5 h-1.5 bg-white -left-[3px] top-2"></div>
            <h3 class="font-bold text-white text-lg mb-2 uppercase tracking-wide">Bukan Harga Murah</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Kami menjual efisiensi tingkat korporat. Kami jamin Anda mendapatkan kualitas kelas atas yang tak akan didapatkan dari freelancer harian.</p>
          </li>
        </ul>
      </div>

      <!-- Right Column: Form -->
      <div class="lg:w-7/12 p-6 lg:p-12 relative bg-slate-950/50">
        <form id="consultation-form" class="flex flex-col h-full">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <div class="relative group">
              <label for="name" class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2 group-focus-within:text-white transition-colors">Nama / Perwakilan</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="block w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-white transition-colors"
                placeholder="Cth: John Doe"
              />
            </div>

            <div class="relative group">
              <label for="company" class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2 group-focus-within:text-white transition-colors">Nama Perusahaan</label>
              <input
                type="text"
                id="company"
                name="company"
                required
                class="block w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-white transition-colors"
                placeholder="Cth: PT Sukses Makmur"
              />
            </div>
          </div>

          <div class="relative group mb-12 flex-grow">
            <label for="brief" class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2 group-focus-within:text-white transition-colors">Deskripsi Singkat Tantangan Bisnis</label>
            <textarea
              id="brief"
              name="brief"
              rows="4"
              required
              class="block w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-white transition-colors resize-none"
              placeholder="Ceritakan masalah utama (bottleneck) yang ingin Anda selesaikan..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="mt-auto inline-flex items-center justify-center gap-3 w-full lg:w-auto self-start px-10 py-5 bg-white text-black font-bold uppercase tracking-widest text-sm hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.3)]"
          >
            <span>Kirim via WhatsApp</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>
      </div>
      
    </section>

    <!-- Bottom Nodes -->
    <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
    <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('consultation-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const company = (document.getElementById('company') as HTMLInputElement).value;
      const brief = (document.getElementById('brief') as HTMLTextAreaElement).value;
      
      const rawMessage = `*INISIASI PROYEK BARU*\n\n*Nama:* ${name}\n*Perusahaan:* ${company}\n*Tantangan Bisnis:* ${brief}\n\nMohon bantuannya untuk menjadwalkan Discovery Call.`;
      const encodedMessage = encodeURIComponent(rawMessage);
      
      window.open(`https://wa.me/6285157445924?text=${encodedMessage}`, '_blank', 'noopener,noreferrer');
    });
  }
</script>
