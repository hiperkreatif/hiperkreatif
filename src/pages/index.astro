---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogoUrl from "../assets/logo-black.svg?url";
import { SEO } from "../constants/seo";
import { SERVICES } from "../constants/services";
import { FAQS } from "../constants/faqs";
import Button from "../components/Button.astro";
import Hero from "../components/Hero.astro";
import TechMarquee from '../components/TechMarquee.astro';
const logo = LogoUrl;
---

<BaseLayout>
  <!-- Architectural Layout Grid -->
  <div class="max-w-7xl mx-auto border-x border-white/10 relative">
    
    <!-- Top Nodes -->
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -left-[3px] z-30"></div>
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -right-[3px] z-30"></div>
    <section class="relative pt-24 pb-40 lg:pt-32 lg:pb-48 overflow-hidden flex flex-col items-center justify-center border-b border-white/10">
      <div class="absolute inset-0 z-0 bg-grid-pattern pointer-events-none"></div>
      
      <!-- Moving Beams -->
      <div class="absolute left-[15%] top-0 h-full w-[1px]"><div class="moving-beam" style="animation-delay: 0s;"></div></div>
      <div class="absolute left-[35%] top-0 h-full w-[1px]"><div class="moving-beam" style="animation-delay: -1.5s;"></div></div>
      <div class="absolute left-[65%] top-0 h-full w-[1px]"><div class="moving-beam" style="animation-delay: -0.8s;"></div></div>
      <div class="absolute left-[85%] top-0 h-full w-[1px]"><div class="moving-beam" style="animation-delay: -3s;"></div></div>

      <!-- Glow blobs -->
      <div class="glow-blob bg-white/10 w-[500px] h-[500px] -top-32 -left-32"></div>
      <div class="glow-blob delay-5s bg-white/5 w-[400px] h-[400px] top-32 -right-32"></div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card text-sm text-gray-300 mb-8 animate-on-scroll" style="transition-delay: 0ms;">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Agency Jasa Website & Otomasi AI untuk bisnis modern
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 animate-on-scroll leading-tight md:leading-tight" style="transition-delay: 100ms;">
          <span class="block text-white pb-2">Dirancang untuk <span class="font-script font-bold text-6xl md:text-8xl tracking-normal">Solusi.</span></span>
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-300 to-gray-500 pb-2">Dibangun untuk Profitabilitas.</span>
        </h1>

        <p class="mt-4 text-xl text-gray-400 max-w-2xl mx-auto mb-10 animate-on-scroll" style="transition-delay: 200ms;">
          Berhenti membuang waktu pada sistem digital yang lambat dan tidak efisien. Kami membangun website super cepat, aplikasi kustom presisi, dan otomasi AI yang memangkas biaya serta melipatgandakan ROI bisnis Anda.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll" style="transition-delay: 300ms;">
          <a href="/consultation" class="px-8 py-4 bg-white text-slate-950 font-bold uppercase tracking-widest text-sm hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.3)]">
            Atasi Kendala Bisnis Anda
          </a>
          <a href="#services" class="px-8 py-4 border-2 border-white/20 text-white font-bold uppercase tracking-widest text-sm hover:border-white transition-colors">
            Jelajahi Ekosistem Kami
          </a>
        </div>
      </div>

      <div class="w-full absolute bottom-0 left-0">
        <TechMarquee />
        <!-- Marquee Nodes -->
        <div class="absolute w-1.5 h-1.5 bg-white top-0 -left-[3px] z-20"></div>
        <div class="absolute w-1.5 h-1.5 bg-white top-0 -right-[3px] z-20"></div>
      </div>
      
      <!-- Hero Bottom Nodes -->
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>
    </section>

    <!-- STATS -->
    <section class="py-12 md:py-20 relative z-10 border-b border-white/10" aria-label="Statistik">
      <!-- Section Nodes -->
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>
      
      <div class="max-w-7xl mx-auto border-y border-white/10 bg-white/[0.01] animate-on-scroll">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-white/10">
          {[ 
            { val: "15+", label: "Proyek B2B Diselesaikan" },
            { val: "-60%", label: "Reduksi Biaya Operasional" },
            { val: "99.9%", label: "Uptime & Reliabilitas" },
            { val: "24/7", label: "Sistem Bisnis Otomatis" }
          ].map(stat => (
            <div class="p-8 md:p-12 text-center hover:bg-white/[0.04] transition-colors flex flex-col justify-center relative group">
              <p class="text-5xl md:text-6xl font-black text-white tracking-tighter mb-3 group-hover:scale-110 transition-transform duration-500">{stat.val}</p>
              <p class="text-xs md:text-sm text-gray-400 font-bold uppercase tracking-widest">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="py-24 relative z-10 border-b border-white/10" aria-labelledby="services-title">
      <!-- Section Nodes -->
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>

      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 animate-on-scroll px-4 lg:px-8">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-white text-sm font-medium mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
            Ekosistem Solusi Terintegrasi
          </div>
          <h2 id="services-title" class="text-4xl md:text-5xl font-bold text-white tracking-tight">
            Sistem Cerdas untuk <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-300 to-gray-500">Pertumbuhan Bisnis.</span>
          </h2>
        </div>
        <a
          href="/consultation"
          class="inline-flex items-center gap-2 px-6 py-3 animated-border text-sm font-medium text-white transition-all hover:scale-105"
        >
          Diskusikan masalah bisnis Anda 
          <span class="group-hover:translate-x-1 transition-transform">-&gt;</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 relative border-t border-white/10">
        <!-- Center Node (Crosshair) -->
        <div class="hidden md:block absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 bg-white z-30 shadow-[0_0_15px_rgba(255,255,255,0.8)]"></div>
        
        {SERVICES.map((s, i) => (
          <div class={`relative group p-8 lg:p-14 overflow-hidden border-b border-white/10 hover:bg-white/[0.06] transition-colors duration-300 flex flex-col min-h-[480px] ${i % 2 === 0 ? 'md:border-r border-white/10' : ''}`}>
            
            <!-- Huge Background Number -->
            <div class="absolute -right-8 -bottom-16 text-[200px] font-black text-white/[0.03] group-hover:text-white/[0.09] transition-colors duration-700 leading-none select-none">
              0{i + 1}
            </div>

            <!-- Content -->
            <div class="relative z-10 flex-grow">
              <div class="inline-flex items-center gap-2 text-xs font-bold px-3 py-1.5 bg-white/10 text-white mb-8 border border-white/20 uppercase tracking-widest backdrop-blur-sm">
                <span class="w-1.5 h-1.5 bg-white animate-pulse"></span>
                {s.badge}
              </div>
              
              <h3 class="text-3xl lg:text-4xl font-extrabold text-white mb-4 tracking-tight">{s.name}</h3>
              <p class="text-gray-300 leading-relaxed mb-8 max-w-md text-lg">{s.tagline}</p>

              <ul class="space-y-4 text-gray-400 mb-12">
                {s.bullets.slice(0, 3).map((b) => (
                  <li class="flex gap-4 items-start">
                    <div class="w-1.5 h-1.5 bg-white/50 shrink-0 mt-2"></div>
                    <span class="text-sm">{b}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="relative z-10 mt-auto">
              <a href={s.cta} class="group/cta inline-flex items-center gap-3 text-white font-bold uppercase text-sm tracking-widest">
                <span class="group-hover/cta:translate-x-1 transition-transform duration-300 inline-block">Pelajari Detail</span>
                <span class="w-8 h-[1px] bg-white group-hover:w-16 group-hover/cta:w-16 transition-all duration-300"></span>
                <svg class="w-4 h-4 group-hover/cta:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
            
          </div>
        ))}
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="py-12 md:py-24 relative z-10 border-b border-white/10" aria-labelledby="process-title">
      <!-- Section Nodes -->
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>

      <div class="max-w-7xl mx-auto border-t border-white/10">
        <div class="flex flex-col lg:flex-row border-b border-white/10">
          <div class="lg:w-1/3 p-8 md:p-12 border-b lg:border-b-0 lg:border-r border-white/10 bg-white/[0.02]">
            <h2 id="process-title" class="text-3xl md:text-5xl font-black text-white tracking-tight uppercase mb-4">
              Cara Kerja
            </h2>
            <p class="text-gray-400 text-lg">Cepat, terukur, dan berorientasi hasil.</p>
            <a href="/consultation" class="mt-8 inline-block px-6 py-3 bg-white text-black font-bold uppercase text-sm tracking-widest hover:bg-gray-200 transition-colors">Konsultasi Sekarang</a>
          </div>
          
          <ol class="lg:w-2/3 grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
            <li class="p-8 group hover:bg-white/[0.04] transition-colors relative border-b sm:border-b-0 border-white/10">
              <div class="text-6xl font-black text-white/[0.05] mb-4 group-hover:text-white/10 transition-colors">01</div>
              <h3 class="font-bold text-white text-xl mb-3">Ngobrol & Diskusi</h3>
              <p class="text-gray-400 leading-relaxed">Kita teleponan. Anda ceritakan pusingnya di mana, kami siapkan solusinya.</p>
            </li>
            <li class="p-8 group hover:bg-white/[0.04] transition-colors relative border-b sm:border-b-0 border-white/10">
              <div class="text-6xl font-black text-white/[0.05] mb-4 group-hover:text-white/10 transition-colors">02</div>
              <h3 class="font-bold text-white text-xl mb-3">Blueprint Eksak</h3>
              <p class="text-gray-400 leading-relaxed">Kami buatkan gambarannya secara detil. Tidak ada asumsi, semuanya terukur.</p>
            </li>
            <li class="p-8 group hover:bg-white/[0.04] transition-colors relative sm:border-t border-white/10 border-b sm:border-b-0 border-white/10">
              <div class="text-6xl font-black text-white/[0.05] mb-4 group-hover:text-white/10 transition-colors">03</div>
              <h3 class="font-bold text-white text-xl mb-3">Eksekusi Terukur</h3>
              <p class="text-gray-400 leading-relaxed">Tim kami langsung merakit sistemnya. Anda terima laporan progres matang.</p>
            </li>
            <li class="p-8 group hover:bg-white/[0.04] transition-colors relative sm:border-t border-white/10 border-b sm:border-b-0 border-white/10">
              <div class="text-6xl font-black text-white/[0.05] mb-4 group-hover:text-white/10 transition-colors">04</div>
              <h3 class="font-bold text-white text-xl mb-3">Rilis & Profit</h3>
              <p class="text-gray-400 leading-relaxed">Sistem aktif. Kami pandu tim Anda sampai 100% mandiri pakai mesin barunya.</p>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- GUARANTEE -->
    <section id="guarantee" class="py-16 md:py-24 relative z-10 border-b border-white/10 bg-white/[0.02]" aria-labelledby="guarantee-title">
      <!-- Section Nodes -->
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>

      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 id="guarantee-title" class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-6">Garansi Kepuasan</h2>
        <p class="text-lg md:text-xl text-gray-300 font-medium leading-relaxed max-w-3xl mx-auto">
          Jika sistem yang kami bangun gagal memberikan hasil yang dijanjikan, kami akan kembalikan investasi Anda. Kami hanya menerima pembayaran untuk solusi yang benar-benar berhasil.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="py-24 relative z-10" aria-labelledby="faq-title">
      <div class="max-w-4xl mx-auto px-4">
        <h2 id="faq-title" class="text-4xl md:text-5xl font-black text-white mb-12 text-center uppercase tracking-tighter">
          Pertanyaan Umum
        </h2>

        <div class="border-t border-white/10" role="list">
          {
            FAQS.map((f, index) => (
              <details class="group border-b border-white/10 bg-transparent hover:bg-white/[0.02] transition-colors">
                <summary class="font-bold text-lg md:text-xl text-white cursor-pointer list-none flex justify-between items-center py-6 px-4 outline-none">
                  {f.q}
                  <span class="transition-transform group-open:rotate-45 text-white/50 group-hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                  </span>
                </summary>
                <div class="px-4 pb-8 text-gray-400 leading-relaxed text-base md:text-lg">
                  {f.a}
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- DOCUMENT GENERATOR LINK -->
    <!-- <section class="px-6 mt-12">
      <div class="bg-white rounded-2xl p-6 border-2 border-gray-100 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Document Generator</h2>
        <p class="text-gray-700 mb-6">Buat dokumen profesional seperti quotation, invoice, kontrak, dan lainnya</p>
        <a
          href="/documents"
          class="inline-flex items-center gap-2 h-12 px-6 rounded-full border-2 border-gray-900 bg-gray-900 text-white font-semibold transition-all duration-300 hover:shadow-xl"
        >
          Akses Document Generator
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section> -->
  </div>

