---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogoUrl from "../assets/logo-black.svg?url";
import { SEO } from "../constants/seo";
import { SERVICES } from "../constants/services";
import { FAQS } from "../constants/faqs";
import Button from "../components/Button.astro";
import Hero from "../components/Hero.astro";
import TechMarquee from '../components/TechMarquee.astro';
const logo = LogoUrl;
---

<BaseLayout>
  <div class="max-w-6xl mx-auto">
    <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden flex flex-col items-center justify-center min-h-[90vh]">
      <!-- Glow blobs -->
      <div class="glow-blob bg-blue-500/30 w-[500px] h-[500px] -top-32 -left-32"></div>
      <div class="glow-blob bg-purple-500/30 w-[400px] h-[400px] top-32 -right-32"></div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card text-sm text-gray-300 mb-8 animate-on-scroll">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Tersedia untuk project baru di 2026
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 animate-on-scroll">
          <span class="block text-white">We Build Digital</span>
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-purple-400 to-indigo-400">Experiences that Scale</span>
        </h1>

        <p class="mt-4 text-xl text-gray-400 max-w-2xl mx-auto mb-10 animate-on-scroll">
          Hiperkreatif membantu bisnis bertransformasi secara digital dengan solusi web dan AI modern, cepat, dan elegan.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
          <a href="/contact" class="px-8 py-4 bg-white text-slate-950 font-bold rounded-lg hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.3)]">
            Mulai Project Baru
          </a>
          <a href="#services" class="px-8 py-4 glass-card text-white font-bold rounded-lg hover:bg-white/10 transition-colors">
            Lihat Layanan
          </a>
        </div>
      </div>

      <div class="w-full absolute bottom-0 left-0">
        <TechMarquee />
      </div>
    </section>

    <!-- STATS -->
    <section class="mt-20 relative z-10" aria-label="Statistik">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 animate-on-scroll">
        {[ 
          { val: "100+", label: "Proyek Selesai" },
          { val: "50+", label: "Klien Puas" },
          { val: "24/7", label: "Dukungan Tersedia" },
          { val: "99%", label: "Tingkat Kepuasan" }
        ].map(stat => (
          <div class="glass-card rounded-2xl p-6 text-center hover:bg-white/10 transition-colors">
            <p class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-white to-gray-400">{stat.val}</p>
            <p class="text-sm text-gray-400 mt-2 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="mt-32 relative z-10" aria-labelledby="services-title">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 animate-on-scroll">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-medium mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
            Keahlian Kami
          </div>
          <h2 id="services-title" class="text-4xl md:text-5xl font-bold text-white tracking-tight">
            Solusi Digital <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">End-to-End</span>
          </h2>
        </div>
        <a
          href="/consultation"
          class="inline-flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors group"
        >
          Konsultasi Kebutuhan Anda 
          <span class="group-hover:translate-x-1 transition-transform">-&gt;</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {SERVICES.map((s, i) => (
          <div class={`glass-card rounded-3xl p-8 relative overflow-hidden group hover:-translate-y-1 transition-all duration-300 animate-on-scroll flex flex-col ${
            i === 0 ? "md:col-span-2 md:row-span-2 min-h-[400px]" :
            i === 3 ? "md:col-span-3 min-h-[250px]" : "min-h-[250px]"
          }`}>
            <!-- Background Decoration -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-gradient-to-br from-white/5 to-transparent rounded-full blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
            
            <div class="relative z-10 flex-grow">
              <div class="inline-flex items-center gap-2 text-xs font-bold px-3 py-1.5 rounded-lg bg-white/10 text-white mb-6 backdrop-blur-sm border border-white/5">
                {s.badge}
              </div>
              <h3 class={`font-bold text-white mb-3 ${i === 0 ? "text-3xl" : "text-2xl"}`}>{s.name}</h3>
              <p class="text-gray-400 leading-relaxed mb-6 max-w-xl">{s.tagline}</p>

              <ul class="space-y-3 text-gray-300 mb-8">
                {s.bullets.map((b) => (
                  <li class="flex gap-3 items-start">
                    <svg class="w-5 h-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-sm">{b}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="relative z-10 mt-auto pt-6 border-t border-white/10">
              <a href={s.cta} class="inline-flex items-center gap-2 text-white font-medium hover:text-blue-400 transition-colors">
                Pelajari selengkapnya 
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="mt-12" aria-labelledby="process-title">
      <div class="bg-white rounded-2xl p-6 border-2 border-gray-100">
        <div class="flex items-center justify-between gap-4 mb-6">
          <h2 id="process-title" class="text-3xl font-bold text-gray-900">
            Proses Kerja
          </h2>
          <a
            href="/consultation"
            class="text-sm font-medium text-gray-900 underline decoration-2 underline-offset-4"
            >Mulai konsultasi</a
          >
        </div>

        <ol class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          <li class="rounded-2xl border-2 border-gray-100 p-6 bg-white">
            <div
              class="h-9 w-9 rounded-full bg-gray-900 text-white flex items-center justify-center font-bold mb-3"
            >
              1
            </div>
            <h3 class="font-semibold text-gray-900">Diagnosa Singkat</h3>
            <p class="text-sm text-gray-700 mt-1">
              Call 20–30 menit: goal, hambatan, prioritas 30 hari.
            </p>
          </li>
          <li class="rounded-2xl border-2 border-gray-100 p-6 bg-white">
            <div
              class="h-9 w-9 rounded-full bg-gray-900 text-white flex items-center justify-center font-bold mb-3"
            >
              2
            </div>
            <h3 class="font-semibold text-gray-900">Rencana & Scope</h3>
            <p class="text-sm text-gray-700 mt-1">
              Dokumen singkat: deliverable, timeline, biaya.
            </p>
          </li>
          <li class="rounded-2xl border-2 border-gray-100 p-6 bg-white">
            <div
              class="h-9 w-9 rounded-full bg-gray-900 text-white flex items-center justify-center font-bold mb-3"
            >
              3
            </div>
            <h3 class="font-semibold text-gray-900">Build & Iterasi</h3>
            <p class="text-sm text-gray-700 mt-1">
              Sprint cepat + demo mingguan, revisi minor on the fly.
            </p>
          </li>
          <li class="rounded-2xl border-2 border-gray-100 p-6 bg-white">
            <div
              class="h-9 w-9 rounded-full bg-gray-900 text-white flex items-center justify-center font-bold mb-3"
            >
              4
            </div>
            <h3 class="font-semibold text-gray-900">Go-Live & Support</h3>
            <p class="text-sm text-gray-700 mt-1">
              Launch terukur, dokumentasi, 7–30 hari support.
            </p>
          </li>
        </ol>

        <div class="mt-6 rounded-xl border-2 border-gray-100 p-4 bg-gray-50">
          <p class="text-sm text-gray-800">
            Jaminan tenang: revisi minor 7 hari pasca go-live + SLA respon 48
            jam kerja untuk issue kritis.
          </p>
        </div>
      </div>
    </section>

    <!-- GUARANTEE -->
    <section id="guarantee" class="mt-8" aria-labelledby="guarantee-title">
      <div class="bg-white rounded-2xl p-5 border-2 border-gray-900">
        <h2 id="guarantee-title" class="sr-only">Garansi</h2>
        <p class="text-sm md:text-base text-gray-900 text-center">
          <span class="font-semibold">Garansi:</span> uang muka <strong
            >full refund</strong
          > jika draft wireframe tidak terkirim dalam <strong
            >7 hari kerja</strong
          >. Free fix 7 hari pasca go-live untuk bug minor.
        </p>
      </div>
    </section>

    <!-- FAQ: single column on mobile, 2 columns on md+ -->
    <section id="faq" class="mt-12" aria-labelledby="faq-title">
      <div class="bg-white rounded-2xl p-6 border-2 border-gray-100">
        <h2 id="faq-title" class="text-3xl font-bold text-gray-900 mb-6">
          FAQ
        </h2>

        <!-- Wrapper: single column on mobile, grid 2-col on md+ -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
          {
            FAQS.map((f, index) => (
              <div class="overflow-hidden">
                <details class="rounded-xl border border-gray-200 p-4 bg-white w-full">
                  <summary class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center">
                    {f.q}
                  </summary>
                  <p class="mt-2 text-sm text-gray-700 pt-2">{f.a}</p>
                </details>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- DOCUMENT GENERATOR LINK -->
    <!-- <section class="px-6 mt-12">
      <div class="bg-white rounded-2xl p-6 border-2 border-gray-100 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Document Generator</h2>
        <p class="text-gray-700 mb-6">Buat dokumen profesional seperti quotation, invoice, kontrak, dan lainnya</p>
        <a
          href="/documents"
          class="inline-flex items-center gap-2 h-12 px-6 rounded-full border-2 border-gray-900 bg-gray-900 text-white font-semibold transition-all duration-300 hover:shadow-xl"
        >
          Akses Document Generator
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section> -->
  </div>

  <!-- JSON-LD @graph tetap di head -->
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://www.hiperkreatif.com/#org",
          name: "Hiperkreatif",
          url: "https://www.hiperkreatif.com/",
          logo: {
            "@type": "ImageObject",
            url: logo,
            width: 112,
            height: 112,
          },
          sameAs: [
            "https://github.com/hiperkreatif",
            "https://wa.me/6285157445924",
          ],
          contactPoint: [
            {
              "@type": "ContactPoint",
              contactType: "customer support",
              telephone: "+628157445924", // pakai E.164
              email: "hi@hiperkreatif.com",
              availableLanguage: "id",
            },
          ],
          founder: { "@id": "https://www.hiperkreatif.com/#person" },
        },

        {
          "@type": "Person",
          "@id": "https://www.hiperkreatif.com/#person",
          name: "Kang Dadan",
          jobTitle: "Software Engineer & Solo Founder",
          url: "https://www.hiperkreatif.com/",
          image: "https://www.hiperkreatif.com/dadan.jpg",
          worksFor: { "@id": "https://www.hiperkreatif.com/#org" },
        },

        {
          "@type": "WebSite",
          "@id": "https://www.hiperkreatif.com/#website",
          url: "https://www.hiperkreatif.com/",
          name: "Hiperkreatif",
          publisher: { "@id": "https://www.hiperkreatif.com/#org" },
          inLanguage: "id-ID",
          potentialAction: {
            "@type": "SearchAction",
            target:
              "https://www.hiperkreatif.com/search?q={search_term_string}",
            "query-input": "required name=search_term_string",
          },
        },

        {
          "@type": "WebPage",
          "@id": "https://www.hiperkreatif.com/#webpage",
          url: "https://www.hiperkreatif.com/",
          name: SEO.title,
          description: SEO.description,
          isPartOf: { "@id": "https://www.hiperkreatif.com/#website" },
          about: { "@id": "https://www.hiperkreatif.com/#org" },
          primaryImageOfPage: {
            "@type": "ImageObject",
            url: `https://www.hiperkreatif.com${SEO.ogImage || "/og-cover-1200x630.jpg"}`,
            width: 1200,
            height: 630,
          },
        },

        // NAVIGATION / SITEMAP-LIKE — bantu Google kenalin link penting (sitelinks candidate)
        {
          "@type": "SiteNavigationElement",
          name: "Primary navigation",
          url: "https://www.hiperkreatif.com/",
          about: [
            {
              "@type": "WebPage",
              name: "HyperSite Commerce",
              url: "https://www.hiperkreatif.com/services/hypersite-commerce",
            },
            {
              "@type": "WebPage",
              name: "HyperProfile Site",
              url: "https://www.hiperkreatif.com/services/hyperprofile-site",
            },
            {
              "@type": "WebPage",
              name: "HyperBuild Custom",
              url: "https://www.hiperkreatif.com/services/hyperbuild-custom",
            },
            {
              "@type": "WebPage",
              name: "Gen-AI Solutions",
              url: "https://www.hiperkreatif.com/services/gen-ai-solutions",
            },
          ],
        },

        // DESKRIPSI LAYANAN EXPLICIT — Google loves explicit entities
        {
          "@type": "Service",
          "@id": "https://www.hiperkreatif.com/services/hypersite-commerce",
          name: "HyperSite Commerce",
          serviceType: "E-commerce Development",
          url: "https://www.hiperkreatif.com/services/hypersite-commerce",
          provider: { "@id": "https://www.hiperkreatif.com/#org" },
          description:
            "Toko online kencang, aman, SEO-ready, integrasi pembayaran & CRM.",
        },
        {
          "@type": "Service",
          "@id": "https://www.hiperkreatif.com/services/hyperprofile-site",
          name: "HyperProfile Site",
          serviceType: "Company Profile Website",
          url: "https://www.hiperkreatif.com/services/hyperprofile-site",
          provider: { "@id": "https://www.hiperkreatif.com/#org" },
          description:
            "Company profile profesional, CMS ramah editor, multi bahasa opsional.",
        },
        {
          "@type": "Service",
          "@id": "https://www.hiperkreatif.com/services/hyperbuild-custom",
          name: "HyperBuild Custom",
          serviceType: "Custom Web & App Development",
          url: "https://www.hiperkreatif.com/services/hyperbuild-custom",
          provider: { "@id": "https://www.hiperkreatif.com/#org" },
          description:
            "Solusi custom untuk workflow, integrasi API, dan automasi bisnis.",
        },
        {
          "@type": "Service",
          "@id": "https://www.hiperkreatif.com/services/gen-ai-solutions",
          name: "Gen-AI Solutions",
          serviceType: "Generative AI & Automation",
          url: "https://www.hiperkreatif.com/services/gen-ai-solutions",
          provider: { "@id": "https://www.hiperkreatif.com/#org" },
          description:
            "Asisten AI, RAG untuk SOP & katalog, chat CS otomatis, integrasi multichannel.",
        },
      ],
    })}
  />

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.animate-on-scroll').forEach((el) => {
      observer.observe(el);
    });
  </script>
</BaseLayout>
