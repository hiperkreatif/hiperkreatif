---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Halaman Tidak Ditemukan | Hiperkreatif">
  <!-- Architectural Layout Grid -->
  <div class="w-full max-w-7xl mx-auto border-x border-white/10 relative min-h-[85vh] flex flex-col justify-center items-center py-24 px-6 lg:px-12 overflow-hidden">
    
    <!-- Top Nodes -->
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -left-[3px] z-30"></div>
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -right-[3px] z-30"></div>

    <!-- Background Elements -->
    <div class="absolute inset-0 z-0 bg-grid-pattern pointer-events-none opacity-50"></div>
    <div class="glow-blob bg-white/5 w-[500px] h-[500px] -top-32 -left-32 pointer-events-none"></div>

    <!-- Moving Beams -->
    <div class="absolute left-[30%] top-0 h-full w-[1px] bg-white/5"><div class="moving-beam" style="animation-delay: 0s;"></div></div>
    <div class="absolute left-[70%] top-0 h-full w-[1px] bg-white/5"><div class="moving-beam" style="animation-delay: 2s;"></div></div>

    <!-- Massive Background Number -->
    <div class="absolute right-12 bottom-12 text-[180px] md:text-[300px] font-mono font-bold text-white/[0.02] leading-none select-none pointer-events-none">
      404
    </div>

    <!-- Main Content -->
    <div class="relative z-10 text-center max-w-2xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 text-white mb-8 border border-white/20 font-mono uppercase tracking-widest text-xs font-bold backdrop-blur-sm">
        <span class="w-1.5 h-1.5 bg-red-500 animate-pulse"></span>
        Error: System 404
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6 uppercase">
        Rute Tidak Ditemukan
      </h1>

      <p class="text-lg text-gray-400 mb-12 leading-relaxed">
        Halaman yang Anda cari tidak terdaftar dalam cetak biru sistem kami atau telah dipindahkan ke direktori lain.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-4 bg-white text-slate-950 font-mono font-bold uppercase tracking-widest text-xs hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.3)]">
          Kembali ke Beranda
        </a>
        <a href="https://wa.me/6285157445924?text=Halo%20Hiperkreatif%2C%20saya%20menemukan%20masalah%2Ferror%20404%20saat%20mengakses%20halaman%20di%20website." target="_blank" rel="noopener noreferrer" class="px-8 py-4 border-2 border-white/20 text-white font-mono font-bold uppercase tracking-widest text-xs hover:border-white transition-colors">
          Laporkan Masalah
        </a>
      </div>
    </div>

    <!-- Bottom Nodes -->
    <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
    <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>
  </div>
</BaseLayout>
