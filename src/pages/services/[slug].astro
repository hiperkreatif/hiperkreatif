---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SERVICES } from "../../constants/services";

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Generate contextual WhatsApp link based on service name
const encodedServiceName = encodeURIComponent(service.name);
const whatsappLink = `https://wa.me/6285157445924?text=Halo%20Hiperkreatif,%20saya%20butuh%20bantuan%20terkait%20${encodedServiceName}.%20Boleh%20diskusi?`;
---

<BaseLayout
  title={`${service.name} | Blueprint Efisiensi | Hiperkreatif`}
  description={service.desc}
>
  <!-- Architectural Layout Grid -->
  <div class="w-full max-w-7xl mx-auto border-x border-white/10 relative min-h-screen">
    
    <!-- Top Nodes -->
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -left-[3px] z-30"></div>
    <div class="absolute w-1.5 h-1.5 bg-white top-0 -right-[3px] z-30"></div>

    <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden flex flex-col justify-center border-b border-white/10">
      <div class="absolute inset-0 z-0 bg-grid-pattern pointer-events-none"></div>
      
      <!-- Moving Beams -->
      <div class="absolute left-[30%] top-0 h-full w-[1px] bg-white/5"><div class="moving-beam" style="animation-delay: 0s;"></div></div>
      <div class="absolute left-[70%] top-0 h-full w-[1px] bg-white/5"><div class="moving-beam" style="animation-delay: 2s;"></div></div>

      <div class="container mx-auto px-6 lg:px-12 relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 text-white mb-8 border border-white/20 uppercase tracking-widest text-xs font-bold backdrop-blur-sm">
          <span class="w-1.5 h-1.5 bg-white animate-pulse"></span>
          {service.badge}
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 text-white max-w-4xl">
          {service.name}
        </h1>

        <p class="text-2xl md:text-3xl font-medium text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-300 to-gray-500 mb-8 max-w-3xl leading-snug">
          {service.tagline}
        </p>

        <p class="mt-4 text-lg text-gray-400 max-w-2xl mb-12 leading-relaxed">
          {service.desc}
        </p>

        <a href="/consultation" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-black font-bold uppercase tracking-widest text-sm hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.3)]">
          Mulai Eksekusi Sekarang
        </a>
      </div>
      
      <!-- Hero Bottom Nodes -->
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -left-[3px] z-20"></div>
      <div class="absolute w-1.5 h-1.5 bg-white -bottom-[3px] -right-[3px] z-20"></div>
    </section>

    <!-- KEY FEATURES / BULLETS -->
    <section class="py-24 relative border-b border-white/10">
      <div class="px-6 lg:px-12 mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-white uppercase tracking-tight">Nilai Eksekusi</h2>
        <p class="text-gray-400 mt-2 text-lg">Alasan mengapa solusi ini adalah kunci efisiensi Anda.</p>
      </div>

      <div class="border-t border-white/10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/10">
          {service.bullets.map((b: string, i: number) => (
            <div class="p-8 lg:p-12 group hover:bg-white/[0.02] transition-colors relative">
              <div class="text-5xl font-black text-white/[0.05] mb-6 group-hover:text-white/10 transition-colors">0{i + 1}</div>
              <p class="text-gray-300 font-medium leading-relaxed">{b}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CALL TO ACTION -->
    <section class="py-24 relative bg-white/[0.02]">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-6">Siap Menghancurkan Bottleneck?</h2>
        <p class="text-lg text-gray-400 mb-10 leading-relaxed">
          Jangan biarkan kompetitor mengambil alih pasar Anda sementara Anda sibuk mengurusi sistem yang lambat. Jadwalkan panggilan dengan tim elit kami sekarang.
        </p>
        <a href="/consultation" class="inline-flex items-center justify-center px-10 py-5 border-2 border-white text-white font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-colors">
          Hubungi Tim Ahli
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
