---
import { NAV_LOGO, NAV_MENU, NAV_CTA } from "../constants/navbar.ts";
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

import { Picture } from "astro:assets";
import Logo from "../assets/logo.webp";
import { ClientRouter } from "astro:transitions";
import { SEO as DEFAULTS } from "../constants/seo.ts";
import og from "../assets/og.png";
const ogUrl = new URL(og.src, Astro.site).toString();
import LogoUrl from "../assets/logo-black.svg?url";
const {
  title = DEFAULTS.title,
  description = DEFAULTS.description,
  robots = DEFAULTS.robots,
  //   ogImage = DEFAULTS.ogImage,
  logo = LogoUrl,
  ogImageAlt = DEFAULTS.ogImageAlt,
  ogType = DEFAULTS.ogType,
  twitterCard = DEFAULTS.twitterCard,
  siteName = DEFAULTS.siteName,
} = Astro.props;

// Canonical per halaman, bukan hardcode:
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:logo" content={logo} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <!-- Optional: bantu crawler nemuin sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Schema Markup (JSON-LD) removed to avoid duplication -->

    <!-- Router + prefetch -->
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <header
      transition:name="site-header"
      class="sticky top-0 z-50 bg-transparent backdrop-blur-xl border-b border-gray-100"
    >
      <nav>
        <div
          class="max-w-4xl mx-auto flex items-center justify-between px-6 sm:px-0 py-4"
        >
          <a href="/" class="flex items-center gap-3 group">
            <Picture
              src={Logo}
              alt={NAV_LOGO}
              widths={[40, 48]}
              sizes="(min-width: 768px) 48px, 40px"
              class="h-10 w-10 md:h-12 md:w-12 transition-transform duration-300 group-hover:scale-110"
            />
            <span
              class="font-bold text-2xl md:text-3xl bg-clip-text text-transparent bg-gradient-to-r from-slate-900 to-gray-400"
              >{NAV_LOGO}</span
            >
          </a>

          {/* Desktop Menu */}
          <div class="hidden md:flex items-center gap-6">
            {
              NAV_MENU.map((item) => (
                <a
                  href={item.href}
                  class="relative text-base text-gray-600 font-medium px-2 py-1 hover:text-black transition-colors after:absolute after:left-0 after:bottom-0 after:h-0.5 after:w-0 after:bg-black after:transition-all hover:after:w-full"
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
            <a
              href={NAV_CTA.href}
              class="ml-4 bg-black text-white font-medium text-base px-6 py-2.5 rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300"
              >{NAV_CTA.label}</a
            >
          </div>

          {/* Mobile Menu Button */}
          <button
            class="md:hidden p-2 text-gray-600 hover:text-black focus:outline-none rounded-full hover:bg-gray-100 transition-colors"
            onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>

        {/* Mobile Menu Panel */}
        <div id="mobile-menu" class="hidden md:hidden">
          <div
            class="px-6 pt-4 pb-6 space-y-3 bg-gray-50/80 backdrop-blur-lg border-t border-gray-100"
          >
            {
              NAV_MENU.map((item) => (
                <a
                  href={item.href}
                  class="block text-base text-gray-600 hover:text-black font-medium px-3 py-2.5 rounded-lg hover:bg-white transition-all"
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
            <a
              href={NAV_CTA.href}
              class="block mt-6 bg-black text-white font-medium text-base px-6 py-3 rounded-full text-center shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all duration-300"
              >{NAV_CTA.label}</a
            >
          </div>
        </div>
      </nav>
    </header>
    <main transition:name="page-content">
      <slot />
    </main>
    <footer
      transition:name="site-footer"
      class="mt-12 py-8 md:py-12 border-t border-gray-200 bg-white"
    >
      <div class="max-w-4xl mx-auto px-6 sm:px-0 flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0">
        <!-- Left: Logo -->
        <div class="flex-1 flex justify-center md:justify-start">
          <div class="text-gray-900 font-black tracking-widest uppercase text-xl md:text-2xl">
            HIPERKREATIF
          </div>
        </div>

        <!-- Center: Socials -->
        <div class="flex-none flex items-center justify-center gap-3">
          <a href="https://instagram.com/hiperkreatif" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 border border-gray-200 text-gray-500 hover:bg-gradient-to-tr hover:from-pink-500 hover:to-orange-500 hover:text-white hover:border-transparent hover:shadow-[0_5_15px_rgba(236,72,153,0.4)] transition-all duration-300 hover:scale-110 hover:-translate-y-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
          </a>
          <a href="https://www.tiktok.com/@hiperkreatif" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 border border-gray-200 text-gray-500 hover:bg-black hover:text-white hover:border-white/20 hover:shadow-[0_5_15px_rgba(0,0,0,0.3)] transition-all duration-300 hover:scale-110 hover:-translate-y-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.22-1.15 4.38-2.9 5.66-1.62 1.2-3.72 1.63-5.69 1.19-2.02-.45-3.8-1.8-4.75-3.66-1.02-2-1.06-4.42-.09-6.44 1.06-2.18 3.25-3.64 5.66-3.83.18-.01.37-.02.56-.02v4.06c-1.37.05-2.73.7-3.56 1.81-.88 1.15-1.1 2.75-.54 4.08.5 1.16 1.61 2.05 2.86 2.25 1.5.24 3.12-.22 4.12-1.4.95-1.11 1.25-2.6 1.21-4.04-.04-4.83-.02-9.66-.03-14.49z"/></svg>
          </a>
          <a href="https://www.youtube.com/@hiperkreatif" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 border border-gray-200 text-gray-500 hover:bg-[#FF0000] hover:text-white hover:border-transparent hover:shadow-[0_5_15px_rgba(255,0,0,0.5)] transition-all duration-300 hover:scale-110 hover:-translate-y-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd"/></svg>
          </a>
          <a href="https://facebook.com/hiperkreatif" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 border border-gray-200 text-gray-500 hover:bg-[#1877F2] hover:text-white hover:border-transparent hover:shadow-[0_5_15px_rgba(24,119,242,0.4)] transition-all duration-300 hover:scale-110 hover:-translate-y-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
          </a>
        </div>

        <!-- Right: Copyright -->
        <div class="flex-1 flex justify-center md:justify-end">
          <div class="text-sm text-gray-500 text-center md:text-right font-medium">
            &copy; {new Date().getFullYear()} Hiperkreatif.<br class="hidden xl:block"/> All rights reserved.
          </div>
        </div>
      </div>
    </footer>
    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/6281111111111?text=Halo%20Hiperkreatif,%20saya%20ingin%20berkonsultasi%20tentang%20pembuatan%20website" target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-50 flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-[0_0_20px_rgba(37,211,102,0.4)] hover:scale-110 hover:shadow-[0_0_30px_rgba(37,211,102,0.7)] transition-all duration-300 group" aria-label="Chat via WhatsApp">
      <span class="absolute right-full mr-4 bg-white text-slate-900 text-xs font-bold px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap shadow-lg pointer-events-none">Chat dengan kami</span>
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
    </a>

    <Analytics />
  </body>
</html>
